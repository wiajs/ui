# 统一所有文本文件强制使用 LF 换行符（跨平台通用）
* text=auto eol=lf

# 明确声明这些是文本文件，统一 LF
*.css text eol=lf
*.less text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.ini text eol=lf

# 二进制文件（不处理换行）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.zip binary
*.pdf binary